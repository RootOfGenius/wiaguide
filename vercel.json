{
  "buildCommand": "npm run build",
  "outputDirectory": ".next/static",
  "framework": "nextjs",
  "env": {},
  "functions": {},
  "headers": [
    {
      "source": "/public/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [],
  "redirects": []
}
